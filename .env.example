# Required: Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Required: Pylon API token (https://app.usepylon.com/settings/api-tokens)
PYLON_API_TOKEN=

# Optional: LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=premium-support-highlights
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=

# Optional: disable Pylon tools response cache (set to 0 to disable)
# PYLON_TOOLS_CACHE=1
