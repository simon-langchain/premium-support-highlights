# Required: Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Required: Pylon API token (https://app.usepylon.com/settings/api-tokens)
PYLON_API_TOKEN=

# Optional: LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=premium-support-highlights
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_WORKSPACE_ID=

# Optional: disable Pylon tools response cache (set to 0 to disable)
# PYLON_TOOLS_CACHE=1

# Optional: SMTP config for emailing reports
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@example.com

# Optional: publicly hosted logo PNG URL for email reports.
# When set, emails use <img src="URL"> instead of inline SVG — required for Outlook compatibility.
# REPORT_LOGO_URL=https://your-cdn.com/langchain-logo.png

# Optional: banner image URL shown at the top of emailed reports.
# REPORT_BANNER_URL=https://your-cdn.com/email-banner.png

# Optional: bypass login for local development. Automatically disabled when ALLOWED_ORIGINS is set.
# LOCAL_TEST_MODE=true

# Optional: Slack integration for posting support highlights to customer channels.
# SLACK_BOT_TOKEN=xoxb-...                  Bot token with chat:write, channels:read, groups:read scopes
# SLACK_SIGNING_SECRET=...                  From Slack app Basic Information page (for button callbacks)
# SLACK_OVERRIDE_CHANNEL=C0AR0JE2873        When set, ALL Slack posts go here (use during testing)
# DASHBOARD_URL=https://your-app.vercel.app  Linked from the "View Full Report" button in Slack
#
# For interactive buttons (Post Summary / Post Open Issues) to work, set the
# Interactivity Request URL in your Slack app to: https://{your-frontend}/api/slack/actions
